# Riot
RIOT_API_KEY=
RIOT_RSO_CLIENT_ID=
RIOT_RSO_CLIENT_SECRET=
RIOT_RSO_REDIRECT_URI=http://localhost:3001/auth/riot/callback

# Discord
DISCORD_BOT_TOKEN=
DISCORD_USER_AGENT=valorant_tournament_hosting_framework-discord-bot/0.1.0 (+https://github.com/cedricdcc/valorant_tournament_hosting_framework)
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://localhost:3001/auth/discord/callback

# Platform
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace_with_strong_password
DATABASE_URL=postgresql://postgres:replace_with_strong_password@postgres:5432/valorant_tournament
REDIS_URL=redis://redis:6379
DISCORD_BROKER_CHANNEL=discord.jobs
# Browser-facing URL for local access from host machine.
PUBLIC_BASE_URL=http://localhost:3000
ENFORCE_HTTPS=false

# OAuth state signing
AUTH_LINK_SECRET=replace_with_random_32_char_secret
